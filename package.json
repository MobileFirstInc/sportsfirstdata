{
  "name": "sports-schema",
  "version": "0.1.0",
  "description": "TypeScript schema definitions for sports data — athletes, matches, tournaments, teams, and analytics",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "sports",
    "schema",
    "typescript",
    "athlete",
    "match",
    "tournament",
    "team",
    "analytics",
    "sports-data"
  ],
  "author": "MobileFirstInc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MobileFirstInc/sportsfirstdata.git"
  },
  "homepage": "https://github.com/MobileFirstInc/sportsfirstdata#readme",
  "bugs": {
    "url": "https://github.com/MobileFirstInc/sportsfirstdata/issues"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
